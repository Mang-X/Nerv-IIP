    "@nerv-iip/business-core": "workspace:*",
    "@nerv-iip/ui": "workspace:*",
    "@nerv-iip/ui-mobile": "workspace:*",
    "@pinia/colada": "1.4.2",
    "@lucide/vue": "1.24.0",
    "pinia": "4.0.2",
    "vue": "3.5.39",
    "vue-router": "5.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
