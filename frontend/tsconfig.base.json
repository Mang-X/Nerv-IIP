{
  "compilerOptions": {
    "target": "ES2023",
    "ignoreDeprecations": "6.0",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@nerv-iip/api-client": ["packages/api-client/src/index.ts"],
      "@nerv-iip/app-shell": ["packages/app-shell/src/index.ts"],
      "@nerv-iip/auth": ["packages/auth/src/index.ts"],
      "@nerv-iip/business-core": ["packages/business-core/src/index.ts"],
      "@nerv-iip/ui": ["packages/ui/src/index.ts"],
      "@nerv-iip/ui-mobile": ["packages/ui-mobile/src/index.ts"]
    },
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client", "vitest/globals"]
  }
}
