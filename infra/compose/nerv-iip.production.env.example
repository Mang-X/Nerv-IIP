ASPNETCORE_ENVIRONMENT=Production
DOTNET_ENVIRONMENT=Production
NERV_IIP_IMAGE_TAG=local

NERV_IIP_POSTGRES_USER=nerv
NERV_IIP_POSTGRES_PASSWORD=change-me-strong-postgres-password
NERV_IIP_MINIO_ROOT_USER=change-me-minio-admin
NERV_IIP_MINIO_ROOT_PASSWORD=change-me-strong-minio-password
NERV_IIP_INTERNAL_SERVICE_BEARER_TOKEN=change-me-strong-internal-service-token
NERV_IIP_CONNECTOR_HOST_ID=connector-host-001
NERV_IIP_CONNECTOR_HOST_ORGANIZATION_ID=org-001
NERV_IIP_CONNECTOR_HOST_ENVIRONMENT_ID=env-dev
NERV_IIP_CONNECTOR_HOST_SECRET=change-me-strong-connector-host-secret
NERV_IIP_CONNECTOR_INGESTION_TOKEN_SIGNING_KEY=change-me-at-least-32-bytes-ingestion-token-signing-key
# Provide a complete RSA private key PEM for IAM signing. If your env loader cannot preserve
# multiline values, encode newlines consistently before passing the value to the container.
# NERV_IIP_IAM_JWT_SIGNING_KEY_ID must match a kid in NERV_IIP_IAM_JWT_JWKS_JSON.
NERV_IIP_IAM_JWT_SIGNING_KEY_ID=change-me-rsa-key-id
NERV_IIP_IAM_JWT_PRIVATE_KEY_PEM=change-me-rsa-private-key-pem
NERV_IIP_IAM_JWT_JWKS_JSON={"keys":[{"kty":"RSA","use":"sig","kid":"change-me-rsa-key-id","alg":"RS256","n":"change-me-modulus","e":"AQAB"}]}
NERV_IIP_CORS_ALLOWED_ORIGINS=https://console.example.test,https://business.example.test

NERV_IIP_IAM_SEED_ENABLED=false
NERV_IIP_IAM_SEED_ADMIN_PASSWORD=
NERV_IIP_EXTERNAL_CLIENT_SECRET=
NERV_IIP_IAM_ACCESS_TOKEN_MINUTES=15
NERV_IIP_MESSAGING_PROVIDER=Redis
NERV_IIP_AUTO_MIGRATE=false

# Release-time FileStorage migrator input. Keep this in the operator's process or
# secret manager; do not pass it to scripts/install/migrate-file-storage.ps1 as a CLI argument.
NERV_IIP_FILE_STORAGE_DB=Host=postgres;Port=5432;Database=nerv_iip_filestorage;Username=nerv;Password=change-me-strong-postgres-password
