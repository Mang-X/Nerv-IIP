{
  "AllowedHosts": "*",
  "Persistence": {
    "AutoMigrate": false
  },
  "Messaging": {
    "Provider": "InMemory"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  }
}
