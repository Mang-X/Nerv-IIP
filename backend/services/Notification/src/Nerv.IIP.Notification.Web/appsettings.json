{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Messaging": {
    "Provider": "InMemory"
  },
  "Observability": {
    "Alerts": {
      "Enabled": false,
      "PollInterval": "00:01:00",
      "DedupeWindow": "00:30:00",
      "SilentWindow": "00:10:00",
      "RecipientRefs": [
        "role:ops-admin"
      ],
      "Rules": [
        {
          "RuleId": "service-health-apphub",
          "Name": "AppHub health",
          "Kind": "service-health",
          "Enabled": true,
          "Severity": "critical"
        },
        {
          "RuleId": "notification-dlq-backlog",
          "Name": "Notification CAP/DLQ backlog",
          "Kind": "cap-dlq-backlog",
          "Enabled": true,
          "Severity": "critical",
          "Threshold": 1
        },
        {
          "RuleId": "connector-host-heartbeat-stale",
          "Name": "Connector Host heartbeat stale",
          "Kind": "connector-heartbeat-stale",
          "Enabled": true,
          "Severity": "critical",
          "Threshold": 1,
          "HeartbeatMaxAge": "00:05:00"
        },
        {
          "RuleId": "postgres-connection-watermark",
          "Name": "PostgreSQL connection watermark",
          "Kind": "postgres-watermark",
          "Enabled": true,
          "Severity": "warning",
          "MetricName": "connections",
          "ConnectionStringName": "NotificationDb",
          "WatermarkPercent": 80
        },
        {
          "RuleId": "postgres-database-size-watermark",
          "Name": "PostgreSQL database size watermark",
          "Kind": "postgres-watermark",
          "Enabled": true,
          "Severity": "warning",
          "MetricName": "database-size",
          "ConnectionStringName": "NotificationDb",
          "WatermarkPercent": 85
        }
      ]
    }
  },
  "AllowedHosts": "*"
}
