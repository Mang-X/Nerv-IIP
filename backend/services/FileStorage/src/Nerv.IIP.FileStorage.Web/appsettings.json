{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "FileStorage": {
    "Scanning": {
      "Enabled": false,
      "RequireCleanForDownload": true,
      "UnavailablePolicy": "block",
      "IntervalSeconds": 60,
      "BatchSize": 25,
      "ClamAv": {
        "Host": "localhost",
        "Port": 3310
      }
    },
    "GarbageCollection": {
      "IntervalSeconds": 300,
      "OrphanTusFileGraceSeconds": 300,
      "PhysicalDeleteGraceSeconds": 604800
    },
    "PurposePolicies": {
      "application-package": {
        "AllowedContentTypes": [ "application/zip", "application/octet-stream" ],
        "AllowedExtensions": [ ".zip" ],
        "BlockedExtensions": [ ".exe", ".ps1", ".bat", ".cmd", ".sh" ]
      },
      "avatar": {
        "AllowedContentTypes": [ "image/png", "image/jpeg" ],
        "AllowedExtensions": [ ".png", ".jpg", ".jpeg" ],
        "BlockedExtensions": [ ".exe", ".ps1", ".bat", ".cmd", ".sh" ]
      },
      "attachment": {
        "BlockedExtensions": [ ".exe", ".ps1", ".bat", ".cmd", ".sh" ]
      },
      "diagnostic-log": {
        "AllowedContentTypes": [ "text/plain", "text/csv", "application/json", "application/zip", "application/gzip", "application/octet-stream" ],
        "AllowedExtensions": [ ".txt", ".log", ".csv", ".json", ".zip", ".gz" ],
        "BlockedExtensions": [ ".exe", ".ps1", ".bat", ".cmd", ".sh" ]
      }
    }
  },
  "AllowedHosts": "*"
}
