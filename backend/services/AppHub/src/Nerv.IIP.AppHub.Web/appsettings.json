{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Messaging": {
    "Provider": "InMemory"
  },
  "AppHub": {
    "HeartbeatTimeoutScan": {
      "Enabled": false,
      "PollInterval": "00:01:00",
      "HeartbeatTimeout": "00:05:00",
      "Take": 100
    }
  },
  "AllowedHosts": "*"
}
