# Normalize text line endings in the repository. Git stores tracked text as LF
# and checks it out as LF regardless of each developer's core.autocrlf setting.
* text=auto eol=lf

# C# and EF-generated migration/snapshot files are the highest-churn review
# surface for this repo; keep them explicit even though the global rule covers
# text files.
*.cs text eol=lf

# Binary assets must not be line-ending normalized.
*.bmp -text
*.gif -text
*.ico -text
*.jpg -text
*.jpeg -text
*.png -text
*.webp -text

